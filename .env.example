# Required for the frontier assistant + LLM-as-judge.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# Model IDs (override to swap models)
FRONTIER_MODEL=llama-3.3-70b-versatile
JUDGE_MODEL=llama-3.3-70b-versatile
MODERATOR_MODEL=llama-3.1-8b-instant
OSS_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# Optional: device override for OSS model (cpu / cuda / mps). Auto-detected if unset.
# OSS_DEVICE=cpu

# Optional: where to write structured event logs
LOG_PATH=logs/events.jsonl
